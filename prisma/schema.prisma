model Blog {
  id        String     @id @default(uuid())
  title     String
  content   String
  userId    String
  assetType AssetType?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  assetKey  String?
  slug      String?    @unique
  user      User       @relation(fields: [userId], references: [id])
  comments  Comment[]
  tags      Tag[]      @relation("BlogToTag")
}

model Comment {
  id        String   @id @default(uuid())
  content   String
  blogId    String
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  blog      Blog     @relation(fields: [blogId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])
}

model Tag {
  id    String @id @default(uuid())
  title String @unique
  blogs Blog[] @relation("BlogToTag")
}

model Email {
  id        String   @id @default(uuid())
  title     String   @db.VarChar(100)
  markdown  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Conversation {
  id                                String    @id @default(uuid())
  studentId                         String
  tutorId                           String
  createdAt                         DateTime  @default(now())
  updatedAt                         DateTime  @updatedAt
  User_Conversation_studentIdToUser User      @relation("Conversation_studentIdToUser", fields: [studentId], references: [id], onDelete: Cascade)
  User_Conversation_tutorIdToUser   User      @relation("Conversation_tutorIdToUser", fields: [tutorId], references: [id], onDelete: Cascade)
  Message                           Message[]
}

model Message {
  id                            String       @id @default(uuid())
  conversationId                String
  senderId                      String
  receiverId                    String
  createdAt                     DateTime     @default(now())
  updatedAt                     DateTime     @updatedAt
  content                       String
  isRead                        Boolean      @default(false)
  readAt                        DateTime?
  Conversation                  Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  User_Message_receiverIdToUser User         @relation("Message_receiverIdToUser", fields: [receiverId], references: [id], onDelete: Cascade)
  User_Message_senderIdToUser   User         @relation("Message_senderIdToUser", fields: [senderId], references: [id], onDelete: Cascade)
}

model Sidebar {
  id        String   @id @default(uuid())
  role      RoleType
  tab       String   @db.VarChar(50)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([role, tab])
  @@index([role])
}

model UserActivity {
  id        Int      @id @default(autoincrement())
  userId    String
  page      String
  browser   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}

enum RoleType {
  STUDENT
  TUTOR
  STAFF
  ADMIN
}

enum MeetingType {
  VIRTUAL
  IN_PERSON
}

enum LinkType {
  ZOOM
  TEAM
  MEET
}

enum AssetType {
  IMAGE
  VIDEO
}
